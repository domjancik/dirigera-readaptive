[Unit]
Description=DIRIGERA native Adaptive reconnect recovery
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=piadmin
Group=piadmin
WorkingDirectory=/opt/dirigera-readaptive
Environment=PYTHONPATH=/opt/dirigera-readaptive/src
ExecStart=/opt/dirigera-readaptive/.venv/bin/python -m dirigera_readaptive.cli --config /opt/dirigera-readaptive/config.yaml
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
